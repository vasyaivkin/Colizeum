# Telegram Bot
BOT_TOKEN=your_bot_token_here

# Google Service Account JSON key file path
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google Sheets - Admin table (read-only)
ADMIN_SPREADSHEET_ID=your_admin_spreadsheet_id

# Google Drive - folder for receipts
DRIVE_RECEIPTS_FOLDER_ID=your_drive_folder_id

# Management Spreadsheet (created automatically on first /start, or set manually)
MANAGEMENT_SPREADSHEET_ID=

# Timezone
TIMEZONE=Europe/Moscow

# Database
DATABASE_URL=sqlite+aiosqlite:///data/colizeum.db
